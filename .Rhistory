genelist_vector <- sig_genes$log2FoldChange
names(genelist_vector) <- sig_genes$symbol
cnetplot(ego_down,
foldChange = genelist_vector,
layout = "kk",          # 'kk' is Kamada-Kawai, often cleaner than circular
showCategory = 5,       # Focuses on the top 5 most significant pathways
color_category = "firebrick") +
ggtitle("Gene-Concept Network: Hubs of Resistance")
