# Cluster Profiler
genes_down <- sig_genes[sig_genes$log2FoldChange < 0, "symbol"]
genes_up <- sig_genes[sig_genes$log2FoldChange > 0, "symbol"]
# 2. Run GO Enrichment for Downregulated genes (The "Identity Loss")
ego_down <- enrichGO(gene          = genes_down,
OrgDb         = org.Mm.eg.db,
keyType       = 'SYMBOL',
ont           = "BP", # Biological Process
pAdjustMethod = "BH",
pvalueCutoff  = 0.05)
# 3. Visualizing the top 10 lost pathways
dotplot(ego_down, showCategory=10) +
ggtitle("Pathways Lost in Resistant MEL-R Cells")
gene_symbols <- mapIds(org.Mm.eg.db,
keys=rownames(sig_genes),
column="SYMBOL",
keytype="ENSEMBL",
multiVals="first")
