ggtitle("Pathways Lost in Resistant MEL-R Cells")
# Apply the shrinkage (using the existing coefficient)
resLFC <- lfcShrink(dds_salmon, coef=2, type="apeglm")
# Filter using (p-adj < 0.05 and |LFC| > 1)
