pheatmap(mat_1c_scaled,
breaks = my_breaks,              # Using the -2 to 3 scale from before
legend_breaks = c(-2, -1, 0, 1, 2, 3),
cluster_rows = TRUE,
cluster_cols = FALSE,            # Keep MEL on left, MEL-R on right
show_rownames = TRUE,
fontsize_row = 11,
scale = "none",
annotation_col = as.data.frame(colData(dds_complete)[, "condition", drop=FALSE]),
color = my_colors,
main = "Replication Fig 1C: Histone & Chromatin Signature")
dev.off()
